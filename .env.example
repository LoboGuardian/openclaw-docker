# Copy to .env and fill in your values
# cp .env.example .env

# --- AI Providers (add only what you use) ---
# Free options:
# GEMINI_API_KEY=        → Google Gemini Flash — free tier (aistudio.google.com)
# GROQ_API_KEY=          → Groq — llama-3.3-70b free tier (console.groq.com)
# OPENROUTER_API_KEY=    → OpenRouter — has free models (openrouter.ai)
#
# Paid:
# OPENAI_API_KEY=sk-...
# ANTHROPIC_API_KEY=sk-ant-...
# AWS_ACCESS_KEY_ID=
# AWS_SECRET_ACCESS_KEY=
# AWS_REGION=us-east-1

# --- Messaging integrations ---
# DISCORD_TOKEN=
# TELEGRAM_BOT_TOKEN=
# SLACK_BOT_TOKEN=

# --- Workspace ---
# NODE_ENV=production
